# Cilindro octogonal para demonstrar faces com 4 ou mais vertices.
mtllib cylinder.mtl

v 1 -1 0
v 0.707 -1 0.707
v 0 -1 1
v -0.707 -1 0.707
v -1 -1 0
v -0.707 -1 -0.707
v 0 -1 -1
v 0.707 -1 -0.707
v 1 1 0
v 0.707 1 0.707
v 0 1 1
v -0.707 1 0.707
v -1 1 0
v -0.707 1 -0.707
v 0 1 -1
v 0.707 1 -0.707

usemtl cylinder_side
f 1 9 10 2
f 2 10 11 3
f 3 11 12 4
f 4 12 13 5
f 5 13 14 6
f 6 14 15 7
f 7 15 16 8
f 8 16 9 1

usemtl cylinder_bottom
f 1 2 3 4 5 6 7 8

usemtl cylinder_top
f 16 15 14 13 12 11 10 9
